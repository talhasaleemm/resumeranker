# =========================================================
# ResumeRanker — Environment Variable Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# =========================================================

# --- Application ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-a-long-random-string

# --- PostgreSQL ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=resumeranker
POSTGRES_USER=resumeranker
POSTGRES_PASSWORD=change-me-strong-password

# Composed from the above — used by SQLAlchemy
DATABASE_URL=postgresql+asyncpg://resumeranker:change-me-strong-password@db:5432/resumeranker

# --- File Upload Limits ---
MAX_UPLOAD_SIZE_MB=10

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

# --- spaCy Model ---
SPACY_MODEL=en_core_web_sm

# --- Matching weights ---
TFIDF_WEIGHT=0.4
BM25_WEIGHT=0.4
SKILL_WEIGHT=0.2

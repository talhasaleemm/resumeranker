# =========================================================
# ResumeRanker — Environment Variable Template (Phase 16)
# Copy to .env for local Docker Compose. On Render, set
# sync:false secrets in the Dashboard — never commit .env.
# =========================================================

# --- Application ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001
SECRET_KEY=change-me-to-a-long-random-string

# --- Security (generate before production) ---
# Fernet: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<your-fernet-key-here>
# HMAC:  python -c "import secrets; print(secrets.token_hex(32))"
BLIND_INDEX_KEY=<your-hmac-key-here>

# --- Authentication ---
# JWT:   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<your-jwt-secret-key-here>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- PostgreSQL (docker-compose service name: db) ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=resumeranker
POSTGRES_USER=resumeranker
POSTGRES_PASSWORD=change-me-strong-password

# SQLAlchemy async URL — must use the asyncpg driver
DATABASE_URL=postgresql+asyncpg://resumeranker:change-me-strong-password@db:5432/resumeranker

# --- File Upload Limits ---
MAX_UPLOAD_SIZE_MB=10

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

# --- spaCy NER Pipeline ---
SPACY_MODEL=en_core_web_sm

# --- Matching Weights (must sum to 1.0) ---
TFIDF_WEIGHT=0.4
BM25_WEIGHT=0.4
SKILL_WEIGHT=0.2

# =========================================================
# Render production notes
# =========================================================
# 1. Create the Blueprint from render.yaml (Web + Postgres).
# 2. In the Render Dashboard, set SECRET_KEY, JWT_SECRET_KEY,
#    ENCRYPTION_KEY, and BLIND_INDEX_KEY on resumeranker-api.
# 3. Render's DATABASE_URL uses postgresql:// — the render.yaml
#    start command rewrites it to postgresql+asyncpg:// automatically.
# 4. Uploaded resumes persist under /app/data/uploads inside the
#    container; attach a Render Disk for durable file storage.
